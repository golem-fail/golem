{
  "productName": "GOLEM Test App",
  "version": "0.6.9",
  "identifier": "fail.golem.test",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GOLEM Test App",
        "width": 390,
        "height": 844,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "mobile": [
        { "host": "*", "schemes": ["golem-test"] }
      ]
    }
  }
}
