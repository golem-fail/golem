{
  "productName": "GOLEM Test B",
  "version": "0.1.0",
  "identifier": "fail.golem.test-b",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [{ "title": "GOLEM Test B", "width": 390, "height": 844, "resizable": true }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.png"]
  },
  "plugins": {
    "deep-link": {
      "mobile": [{ "scheme": ["golem-test-b"], "pathPrefix": ["/"] }],
      "desktop": { "schemes": ["golem-test-b"] }
    }
  }
}
